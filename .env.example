# SafetyOf.AI — Environment Variables
# Copy this file to .env.local and fill in your values

# ── AI Model API Keys (Multi-AI Consensus Engine) ──
# At least one is required for consensus to work; all 4 recommended
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_KEY=AI...
DEEPSEEK_API_KEY=sk-...

# ── Stripe Billing ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Auth ──
JWT_SECRET=your-random-secret-min-32-chars

# ── Threat Intelligence (optional — falls back to demo data) ──
PHISHTANK_API_KEY=
ALIENVAULT_API_KEY=

# ── CSOAI Integration ──
CSOAI_API_URL=https://api.csoai.org
CSOAI_API_KEY=

# ── Application ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SafetyOf.AI
NODE_ENV=development
