# SafetyOf.AI Environment Variables
# Copy to .env.local for development

# AI Model API Keys (Multi-AI Consensus Engine)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GEMINI_API_KEY=AI...
DEEPSEEK_API_KEY=sk-...

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/safetyofai

# Authentication
JWT_SECRET=your-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Threat Intelligence APIs
PHISHTANK_API_KEY=your-phishtank-key
ALIENVAULT_API_KEY=your-alienvault-key

# CSOAI Integration
CSOAI_API_URL=https://api.csoai.org
CSOAI_API_KEY=your-csoai-api-key

# Byzantine Council
BYZANTINE_COUNCIL_ENDPOINT=https://byzantine.csoai.org
BYZANTINE_COUNCIL_KEY=your-byzantine-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SafetyOf.AI
NODE_ENV=development
