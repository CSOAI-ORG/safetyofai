{
  "name": "safetyofai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npm run test:pw",
    "test:pw": "npx playwright test",
    "test:pw:ui": "npx playwright test --ui",
    "test:pw:headed": "npx playwright test --headed",
    "test:pw:report": "npx playwright show-report",
    "test:cy": "npx cypress run",
    "test:cy:open": "npx cypress open",
    "test:e2e": "npm run test:pw && npm run test:cy",
    "test:ci": "npm run build && npx playwright install --with-deps chromium && npm run test:pw"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "next": "^14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^14.14.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "cypress": "^13.6.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.21",
